# =============================================================================
# NoCut — Terraform Variables (example)
# Copy to terraform.tfvars and fill in real values.
# =============================================================================

environment            = "dev"
aws_region             = "us-east-1"
s3_bucket_name         = "nocut-media"
cloudfront_key_pair_id = "KXXXXXXXXXXXXXXXXXX"
cloudfront_public_key_pem = <<-EOF
-----BEGIN PUBLIC KEY-----
YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----
EOF
redis_auth_token       = "change-me-to-a-strong-token"

# Supabase
supabase_url               = "https://your-project.supabase.co"
# NOTE: supabase_service_role_key and redis_auth_token are stored in
# AWS Secrets Manager (nocut/supabase-service-role-key, nocut/redis-auth-token)
# and injected into containers at launch — not passed via Terraform variables.

# MediaConvert (for video export assembly)
# Get your endpoint: aws mediaconvert describe-endpoints --region ap-northeast-1 --query 'Endpoints[0].Url' --output text
mediaconvert_endpoint = "https://XXXXXXXX.mediaconvert.ap-northeast-1.amazonaws.com"

# ECS service sizing (defaults are fine for dev)
# transcoder_cpu           = 1024
# transcoder_memory        = 2048
# transcoder_desired_count = 1
# detector_cpu             = 512
# detector_memory          = 1024
# detector_desired_count   = 1
