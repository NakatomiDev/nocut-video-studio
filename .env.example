# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── RevenueCat ──
REVENUECAT_API_KEY=your-revenuecat-api-key
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret
# Web billing public key (exposed to browser via VITE_ prefix)
VITE_REVENUECAT_BILLING_KEY=your-revenuecat-web-billing-key

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# Subscription price IDs (used by RevenueCat webhook to map Stripe purchases → tiers)
STRIPE_PRICE_PRO_MONTHLY=price_1TDehiEifp2JCI8QznuQbDcV
STRIPE_PRICE_PRO_ANNUAL=price_1TDehkEifp2JCI8QDIJUE9r0
STRIPE_PRICE_BUSINESS_MONTHLY=price_1TDehlEifp2JCI8Qk0Gv8OP9
STRIPE_PRICE_BUSINESS_ANNUAL=price_1TDehnEifp2JCI8QnBrWBurb

# ── AWS ──
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=ap-northeast-1
AWS_CLOUDFRONT_KEYPAIR_ID=your-cloudfront-keypair-id

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── GCP / Vertex AI ──
GCP_PROJECT_ID=nocut-ai-dev
GCP_REGION=us-central1
# Full JSON contents of GCP service account key (set as Supabase secret for edge functions)
GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"nocut-ai-dev","private_key_id":"...","private_key":"...","client_email":"nocut-ai-engine@nocut-ai-dev.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
# For local scripts — path to the key file (the script reads GCP_SERVICE_ACCOUNT_KEY directly)
GOOGLE_APPLICATION_CREDENTIALS=infra/gcp-sa-key.json
